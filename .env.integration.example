# Integration Test Credentials
# Copy this file to .env.integration and fill in your values.
#
# These credentials should point to a DEDICATED Azure AD app registration
# used exclusively for integration testing — NOT your daily-use app.
#
# Setup:
#   1. Register a new Azure AD app (see README.md "Create Your Own Azure AD Application")
#   2. Run: M365_CLIENT_ID=<id> M365_TENANT_ID=<tid> m365 login
#      This saves credentials to the path you specify below.
#   3. Fill in the values below and source before running tests:
#      source .env.integration && npx vitest run tests/user.integration.test.js

# Azure AD app registration for integration tests
export M365_INTEGRATION_CLIENT_ID="your-integration-client-id"
export M365_INTEGRATION_TENANT_ID="your-integration-tenant-id"

# Path to the credentials file for the integration test app
# (separate from ~/.m365-cli/credentials.json used by your daily app)
export M365_INTEGRATION_CREDS_PATH="~/.m365-cli/integration-credentials.json"
